# Firebase Configuration
# These values are safe to include in the frontend code (not secrets)
# Copy this file to .env and fill in your actual Firebase config values

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to 'true' on Raspberry Pi to connect to local Firebase emulators in production build
# Default: 'false' (use production Firebase)
VITE_USE_EMULATOR=false
