# Firebase Client Config (for frontend)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
FINGERPRINT_LOGIN_SECRET=change-this-shared-secret-for-the-raspberry-pi-fingerprint-service

# Backend (Cloud Functions uses default credentials)
# For local development with emulators, no additional config needed

# SMS (Production only - Semaphore PH)
SEMAPHORE_API_KEY=your-semaphore-api-key
