rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdminUser() {
      return isAuthenticated() && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'superadmin' ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin'
          )
        )
      );
    }

    function isNotificationOwner() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    function isNotificationReadUpdate() {
      return request.resource.data.userId == resource.data.userId &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['isRead']);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdminUser();
      allow create, update, delete: if false;
    }

    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isAdminUser();

      match /items/{itemId} {
        allow read: if isAuthenticated();
        allow write: if isAdminUser();
      }
    }

    match /serviceRequests/{requestId} {
      allow read: if isAuthenticated() && (
        resource.data.residentId == request.auth.uid ||
        resource.data.assignedWorkerId == request.auth.uid ||
        isAdminUser()
      );
      allow create, update, delete: if false;
    }

    match /disputes/{disputeId} {
      allow read: if isAuthenticated() && (
        resource.data.filedBy == request.auth.uid ||
        resource.data.filedAgainst == request.auth.uid ||
        isAdminUser()
      );
      allow create, update, delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        resource.data.residentId == request.auth.uid ||
        resource.data.workerId == request.auth.uid ||
        isAdminUser()
      );
      allow create, update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isNotificationOwner();
      allow update: if isNotificationOwner() && isNotificationReadUpdate();
      allow create, delete: if false;
    }

    match /requestSignals/{signalId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    match /systemConfig/{configId} {
      allow read: if isAdminUser();
      allow write: if false;
    }

    match /systemLogs/{logId} {
      allow read: if isAdminUser();
      allow write: if false;
    }

    match /otps/{otpId} {
      allow read, write: if false;
    }

    match /emergencies/{emergencyId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }
  }
}
