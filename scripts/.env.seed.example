# Seed credentials for production Firebase demo accounts.
# Copy this file to scripts/.env.seed and fill in your chosen passwords.
# NEVER commit .env.seed — it is listed in .gitignore.

SUPERADMIN_PASSWORD=your-strong-superadmin-password
ADMIN_PASSWORD=your-strong-admin-password
WORKER_PASSWORD=your-strong-worker-password
RESIDENT_PASSWORD=your-strong-resident-password
